# Full cookie string from browser DevTools (recommended — this is all you need)
GIGACHAT_COOKIES=

# Alternative: JWT token from _sm_sess cookie (if not using GIGACHAT_COOKIES)
# GIGACHAT_SM_SESS=

# Optional: auto-fetched from profile API
# GIGACHAT_PROJECT_ID=

# Optional: User-Agent
# - random (default)
# - random/123 (seeded random)
# - any fixed User-Agent string
# GIGACHAT_USER_AGENT=random

# Optional: base URL (default: https://giga.chat)
# GIGACHAT_BASE_URL=https://giga.chat

# Optional: application version (default: 0.94.4)
# GIGACHAT_APP_VERSION=0.94.4

# Optional: language preference (default: en)
# GIGACHAT_LANGUAGE=en

# Optional: timezone (default: UTC)
# GIGACHAT_TIMEZONE=UTC

# Optional: additional cookies
# GIGACHAT_STICKY_DP=
# GIGACHAT_STICKY_KM=
# GIGACHAT_BP_CHALLENGE=
